$xbmSamePath = Join-Path $ScriptDir "wallpaper.xbm"
$bmpSamePath = Join-Path $ScriptDir "wallpaper.bmp"

function Test-PathSafe($path) {
    if ([string]::IsNullOrEmpty($path)) { return $false }
    return Test-Path $path
}

function Find-SdCardXbm {
    foreach ($drive in [System.IO.DriveInfo]::GetDrives()) {
        try {
            if (-not $drive.IsReady) { continue }
            $candidate = Join-Path $drive.RootDirectory.FullName "wallpaper.xbm"
            if ((Test-PathSafe $candidate) -and ($candidate -ne $xbmSamePath)) { return $candidate }
        } catch { continue }
    }
    return $null
}

function Confirm-Overwrite($path) {
    if (Test-Path $path) {
        $ans = Read-Host "'$path' already exists. Overwrite? (Y/N)"
        return ($ans -match '^[Yy]')
    }
    return $true
}

function Get-XbmBytes($xbmText) {
    $m = [regex]::Matches($xbmText, '0x([0-9A-Fa-f]{2})')
    $bytes = New-Object byte[] $m.Count
    for ($i=0; $i -lt $m.Count; $i++) { $bytes[$i] = [Convert]::ToByte($m[$i].Groups[1].Value,16) }
    return $bytes
}

function Convert-XbmToBmp($XbmPath, $BmpPath) {
    $bytes = Get-XbmBytes (Get-Content -Path $XbmPath -Raw)
    if ($bytes.Count -lt 1024) {
        Write-Host "ERROR: xbm data looks incomplete." -ForegroundColor Red
        return $false
    }
    $bmp = New-Object System.Drawing.Bitmap(128,64)
    for ($row=0; $row -lt 64; $row++) {
        for ($col=0; $col -lt 128; $col++) {
            $byteIndex = $row*16 + ($col -shr 3)
            $bitIndex = $col -band 7
            $bit = ($bytes[$byteIndex] -shr $bitIndex) -band 1
            if ($bit -eq 1) { $bmp.SetPixel($col,$row,[System.Drawing.Color]::Black) }
            else { $bmp.SetPixel($col,$row,[System.Drawing.Color]::White) }
        }
    }
    $bmp.Save($BmpPath, [System.Drawing.Imaging.ImageFormat]::Bmp)
    $bmp.Dispose()
    return $true
}

function Convert-BmpToXbm($BmpPath, $XbmPath) {
    $bmp = New-Object System.Drawing.Bitmap($BmpPath)
    if ($bmp.Width -ne 128 -or $bmp.Height -ne 64) {
        Write-Host "ERROR: BMP must be exactly 128x64 (found $($bmp.Width)x$($bmp.Height))." -ForegroundColor Red
        $bmp.Dispose()
        return $false
    }
    $data = New-Object byte[] (16*64)
    for ($row=0; $row -lt 64; $row++) {
        for ($col=0; $col -lt 128; $col++) {
            $px = $bmp.GetPixel($col,$row)
            $lum = 0.3*$px.R + 0.59*$px.G + 0.11*$px.B
            if ($lum -lt 128) {
                $byteIndex = $row*16 + ($col -shr 3)
                $bitIndex = $col -band 7
                $data[$byteIndex] = $data[$byteIndex] -bor (1 -shl $bitIndex)
            }
        }
    }
    $bmp.Dispose()
    $sb = New-Object System.Text.StringBuilder
    [void]$sb.AppendLine("#define wallpaper_width 128")
    [void]$sb.AppendLine("#define wallpaper_height 64")
    [void]$sb.AppendLine("static unsigned char wallpaper_bits[] = {")
    for ($i=0; $i -lt $data.Length; $i+=12) {
        $end = [Math]::Min($i+11, $data.Length-1)
        $chunk = $data[$i..$end]
        $line = "   " + (($chunk | ForEach-Object { "0x{0:x2}" -f $_ }) -join ", ") + ","
        [void]$sb.AppendLine($line)
    }
    [void]$sb.AppendLine("};")
    Set-Content -Path $XbmPath -Value $sb.ToString()
    return $true
}

function Write-MenuItem($num, $name, $color, $location, $found) {
    Write-Host "[$num] File: " -NoNewline
    Write-Host $name -NoNewline -ForegroundColor $color
    if ($found) { Write-Host " FOUND " -NoNewline -ForegroundColor Green }
    else { Write-Host " NOT FOUND " -NoNewline -ForegroundColor Red }
    Write-Host "($location)"
}

function Show-Menu {
    Clear-Host
    Write-Host ("=" * 40) -ForegroundColor DarkCyan
    Write-Host "FoxFW XBM to BMP wallpaper converter" -ForegroundColor Yellow
    Write-Host ("=" * 40) -ForegroundColor DarkCyan
    Write-Host -NoNewline "This tool will convert your "
    Write-Host -NoNewline "wallpaper.xbm" -ForegroundColor Green
    Write-Host -NoNewline " file (located on your SD Card) to a "
    Write-Host -NoNewline ".bmp" -ForegroundColor Blue
    Write-Host " file so that you can edit it in MsPaint (or similar) and save it here."
    Write-Host -NoNewline "When you're ready, convert your "
    Write-Host -NoNewline "wallpaper.bmp" -ForegroundColor Blue
    Write-Host -NoNewline " back to "
    Write-Host -NoNewline "wallpaper.xbm" -ForegroundColor Green
    Write-Host " and place it on your SD Card."
    Write-Host ("=" * 40) -ForegroundColor DarkCyan
    Write-Host "Select a File or Option:" -ForegroundColor Yellow
    Write-Host ""
    $script:xbmSdPath = Find-SdCardXbm
    Write-MenuItem 1 "wallpaper.xbm" "Green" "Same Dir" (Test-PathSafe $xbmSamePath)
    Write-MenuItem 2 "wallpaper.xbm" "Green" "SD Card"  (Test-PathSafe $xbmSdPath)
    Write-MenuItem 3 "wallpaper.bmp" "Blue"  "Same Dir" (Test-PathSafe $bmpSamePath)
    Write-Host "[4] Generate New " -NoNewline
    Write-Host "wallpaper.xbm" -NoNewline -ForegroundColor Green
    Write-Host " (Same Dir)"
    Write-Host "[5] Generate New " -NoNewline
    Write-Host "wallpaper.bmp" -NoNewline -ForegroundColor Blue
    Write-Host " (Same Dir)"
    Write-Host "[6] Exit"
    Write-Host ""
}

function Do-Convert($srcPath, $dstPath, $direction) {
    if (-not (Test-PathSafe $srcPath)) {
        Write-Host "File not found." -ForegroundColor Red
        Start-Sleep -Seconds 1
        return
    }
    Write-Host ""
    Write-Host "[1] Convert"
    Write-Host "[2] Back"
    $sub = Read-Host "Enter Selection"
    if ($sub -ne "1") { return }
    if (-not (Confirm-Overwrite $dstPath)) {
        Write-Host "Cancelled." -ForegroundColor Yellow
        Start-Sleep -Seconds 1
        return
    }
    if ($direction -eq "x2b") { $ok = Convert-XbmToBmp $srcPath $dstPath }
    else { $ok = Convert-BmpToXbm $srcPath $dstPath }
    Write-Host ""
    if ($ok) {
        Write-Host "Successfully converted!" -ForegroundColor Green
        Write-Host "Saved to: $dstPath"
    }
    Read-Host "Press Enter to continue"
}

function Do-GenerateXbm {
    if (-not (Confirm-Overwrite $xbmSamePath)) { return }
    Set-Content -Path $xbmSamePath -Value $templateXbm
    Write-Host ""
    Write-Host "New wallpaper.xbm template created!" -ForegroundColor Green
    Read-Host "Press Enter to continue"
}

function Do-GenerateBmp {
    if (-not (Confirm-Overwrite $bmpSamePath)) { return }
    $tmp = Join-Path $env:TEMP "foxfw_template.xbm"
    Set-Content -Path $tmp -Value $templateXbm
    Convert-XbmToBmp $tmp $bmpSamePath | Out-Null
    Remove-Item $tmp -ErrorAction SilentlyContinue
    Write-Host ""
    Write-Host "New wallpaper.bmp template created!" -ForegroundColor Green
    Read-Host "Press Enter to continue"
}

while ($true) {
        Show-Menu
        $choice = Read-Host "Enter Selection"
        switch ($choice) {
            "1" { Do-Convert $xbmSamePath $bmpSamePath "x2b" }
            "2" { Do-Convert $xbmSdPath $bmpSamePath "x2b" }
            "3" { Do-Convert $bmpSamePath $xbmSamePath "b2x" }
            "4" { Do-GenerateXbm }
            "5" { Do-GenerateBmp }
            "6" { Write-Host ""; Write-Host "Goodbye!" -ForegroundColor Yellow; exit 0 }
            default { Write-Host "Invalid selection." -ForegroundColor Red; Start-Sleep -Seconds 1 }
        }
    }
} catch {
    Write-Host ""
    Write-Host "An error occurred: $_" -ForegroundColor Red
    Read-Host "Press Enter to close"
}
